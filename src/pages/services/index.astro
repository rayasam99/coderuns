---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';

const services = [
  {
    title: 'Digital Transformation',
    href: '/services/digital-transformation',
    desc: 'Reshape your business with cutting-edge digital strategies and modern technology solutions.',
    icon: `<svg class="w-6 h-6 text-[#FD5F18]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'Data Science & Analytics',
    href: '/services/data-science',
    desc: 'Turn raw data into powerful insights that drive smarter business decisions.',
    icon: `<svg class="w-6 h-6 text-[#FD5F18]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
  {
    title: 'Data Engineering',
    href: '/services/data-engineering',
    desc: 'Build robust data pipelines and infrastructure to power your analytics ecosystem.',
    icon: `<svg class="w-6 h-6 text-[#FD5F18]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7M4 7c0-2 1-3 3-3h10c2 0 3 1 3 3M4 7h16M8 12h8M8 16h5"/></svg>`,
  },
  {
    title: 'Data Analytics',
    href: '/services/data-analytics',
    desc: 'Leverage advanced analytics to uncover trends and opportunities in your data.',
    icon: `<svg class="w-6 h-6 text-[#FD5F18]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4v16"/></svg>`,
  },
  {
    title: 'Cloud Computing',
    href: '/services/cloud-computing',
    desc: 'Scale your operations with secure, flexible, and cost-effective cloud solutions.',
    icon: `<svg class="w-6 h-6 text-[#FD5F18]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
  },
  {
    title: 'IT Consulting',
    href: '/services/it-consulting',
    desc: 'Expert guidance to align your IT strategy with your business goals.',
    icon: `<svg class="w-6 h-6 text-[#FD5F18]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: 'Training',
    href: '/services/training',
    desc: 'Empower your team with hands-on IT training programs tailored to your needs.',
    icon: `<svg class="w-6 h-6 text-[#FD5F18]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"/></svg>`,
  },
];
---

<Layout title="Services" description="Explore all IT services offered by Coderuns.">
  <PageHero title="Our Services" />

  <!-- Services Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-325 mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a
            href={service.href}
            class="group border border-gray-100 rounded-2xl p-8 hover:border-[#FD5F18] hover:shadow-md transition-all"
          >
            <div class="w-12 h-12 rounded-xl bg-[#FD5F18]/10 flex items-center justify-center mb-4" set:html={service.icon} />
            <h2 class="cr-heading-md text-[#292929] group-hover:text-[#FD5F18] transition-colors mb-3">{service.title}</h2>
            <p class="cr-body text-[#555]">{service.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
