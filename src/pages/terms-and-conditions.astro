---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Terms and Conditions" description="Read the Coderuns Terms and Conditions.">
  <PageHero title="Terms & Conditions" />

  <!-- Content -->
  <section class="py-20 bg-white">
    <div class="max-w-215 mx-auto px-6">
      <p class="cr-body text-[#555] mb-6">
        By accessing and using Coderuns services, you accept and agree to be bound by the following
        terms and conditions. Please read these carefully before using our services.
      </p>
      <h2 class="cr-heading-md text-[#292929] mb-3">Use of Services</h2>
      <p class="cr-body text-[#555] mb-6">
        You agree to use our services only for lawful purposes and in a manner that does not infringe
        the rights of others or restrict their use of our services.
      </p>
      <h2 class="cr-heading-md text-[#292929] mb-3">Intellectual Property</h2>
      <p class="cr-body text-[#555] mb-6">
        All content, trademarks, and intellectual property on this website are owned by Coderuns LLC
        and may not be reproduced without written permission.
      </p>
      <h2 class="cr-heading-md text-[#292929] mb-3">Limitation of Liability</h2>
      <p class="cr-body text-[#555] mb-6">
        Coderuns shall not be liable for any indirect, incidental, or consequential damages arising
        from your use of our services.
      </p>
      <h2 class="cr-heading-md text-[#292929] mb-3">Contact Us</h2>
      <p class="cr-body text-[#555]">
        For questions regarding these Terms, contact us at
        <a href="mailto:sales@coderuns.com" class="text-[#FD5F18] hover:underline">sales@coderuns.com</a>.
      </p>
    </div>
  </section>
</Layout>
